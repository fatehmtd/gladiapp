{
  "name": "gladiapp",
  "version": "1.0.0",
  "description": "A C++ library for audio processing with REST API and WebSocket support",
  "homepage": "https://github.com/fatehmtd/gladiapp",
  "dependencies": [
    {
      "name": "curl",
      "default-features": false,
      "features": [
        "ssl",
        "websockets"
      ]
    },
    "spdlog",
    "nlohmann-json"
  ]
}